@implements IDisposable
@inject NavigationManager NavigationManager

<aside class="left-pane">
    <div class="nav-section">
        <div class="nav-title">Views</div>
        <button class="nav-item @(IsSettingsView ? "" : "active")" @onclick="@(() => NavigationManager.NavigateTo("/"))">Chat</button>
        <button class="nav-item">Agents</button>
        <button class="nav-item">Tasks</button>
        <button class="nav-item">Memory</button>
        <button class="nav-item @(IsSettingsView ? "active" : "")" @onclick="@(() => NavigationManager.NavigateTo("/settings"))">Settings</button>
    </div>
    <div class="nav-section">
        <div class="nav-title">Shortcuts</div>
        <div class="nav-placeholder">Pinned items will appear here</div>
    </div>
</aside>

@code {
    private bool IsSettingsView => IsSettingsPath(NavigationManager.Uri);

    protected override void OnInitialized()
    {
        NavigationManager.LocationChanged += HandleLocationChanged;
    }

    private void HandleLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    private bool IsSettingsPath(string uri)
    {
        var relative = NavigationManager.ToBaseRelativePath(uri);
        return relative.StartsWith("settings", StringComparison.OrdinalIgnoreCase);
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= HandleLocationChanged;
    }
}