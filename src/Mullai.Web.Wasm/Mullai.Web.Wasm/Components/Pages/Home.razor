@page "/"
@page "/settings"
@rendermode InteractiveServer
@using Markdig

<PageTitle>Mullai</PageTitle>

<div class="app-shell">
    <header class="top-pane">
        <BrandLogo />
        <StatusBadge />
    </header>

    <div class="content-shell">
        <NavMenu />

        <main class="center-pane">
            @if (IsSettingsView)
            {
                <div class="pane-header">
                    <div>
                        <h2>Settings</h2>
                        <p>Manage providers, models, and API keys for Mullai.</p>
                    </div>
                </div>
                <SettingsPanel />
            }
            else
            {
                <div class="pane-header">
                    <div>
                        <h2>Chat</h2>
                        <p>Ask anything and watch the plan unfold.</p>
                    </div>
                    <div class="pane-actions">
                        <button class="ghost-button">New session</button>
                    </div>
                </div>

                <div class="chat-history">
                    @foreach (var entry in ChatState.GetVisibleEntries())
                    {
                        @if (entry is ChatMessage msg)
                        {
                            <ChatMessageItem Message="msg" Pipeline="_pipeline" />
                        }
                        else if (entry is ToolCallSnapshot toolCall)
                        {
                            <ToolCallItem ToolCall="toolCall" />
                        }
                    }
                    @if (ChatState.IsThinking)
                    {
                        <div class="message agent-message thinking-message">
                            <div class="message-content">Thinking...</div>
                        </div>
                    }
                    @if (ChatState.Messages.Count == 0)
                    {
                        <div class="empty-state">
                            <div class="empty-title">Start a new conversation</div>
                            <div class="empty-subtitle">Describe what you want to build, fix, or explore.</div>
                        </div>
                    }
                </div>

                <ChatInput Mode="currentMode" />
            }
        </main>
    </div>
</div>

@code {
    private MarkdownPipeline _pipeline = new MarkdownPipelineBuilder().UseAdvancedExtensions().Build();
}
