@page "/"
@rendermode InteractiveServer
@using Microsoft.Agents.AI
@using Mullai.Agents
@using System.Text
@using Markdig
@inject AgentFactory AgentFactory
@inject IJSRuntime JSRuntime

<PageTitle>Mullai Chat</PageTitle>

<div class="chat-container">
    <div class="chat-header">
        <h2>Mullai Assistant</h2>
    </div>

    <div class="chat-history" @ref="chatHistoryRef">
        @foreach (var msg in messages)
        {
            <div class="message @(msg.IsUser ? "user-message" : "agent-message")">
                <div class="message-content">@((MarkupString)Markdig.Markdown.ToHtml(msg.Content, _pipeline))</div>
            </div>
        }
        @if (isThinking)
        {
            <div class="message agent-message thinking-message">
                <div class="message-content">Thinking...</div>
            </div>
        }
    </div>

    <div class="chat-input-area">
        <textarea @bind="currentInput" @bind:event="oninput" @onkeydown="HandleKeyDown" 
                  placeholder="Ask a question..." rows="1"></textarea>
        <button @onclick="SendMessage" disabled="@(string.IsNullOrWhiteSpace(currentInput) || isThinking)">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
        </button>
    </div>
</div>

<style>
    :root {
        --primary: #6366f1;
        --bg-color: #0f172a;
        --surface: #1e293b;
        --text-primary: #f8fafc;
        --text-secondary: #94a3b8;
        --user-msg: #4f46e5;
        --agent-msg: #334155;
    }

    body {
        margin: 0;
        background-color: var(--bg-color);
        color: var(--text-primary);
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    }
    
    .chat-container {
        display: flex;
        flex-direction: column;
        height: 100vh;
        max-width: 800px;
        margin: 0 auto;
        padding: 1rem;
        box-sizing: border-box;
    }

    .chat-header {
        text-align: center;
        padding: 1rem 0;
        border-bottom: 1px solid var(--surface);
    }
    .chat-header h2 { margin: 0; font-weight: 600; color: var(--text-primary); }
    .chat-header p { margin: 0; color: var(--text-secondary); font-size: 0.9rem; }

    .chat-history {
        flex: 1;
        overflow-y: auto;
        padding: 1rem 0;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        scroll-behavior: smooth;
    }

    .message {
        max-width: 80%;
        display: flex;
    }

    .user-message {
        align-self: flex-end;
    }
    .user-message .message-content {
        background: var(--user-msg);
        border-radius: 1rem 1rem 0 1rem;
    }

    .agent-message {
        align-self: flex-start;
    }
    .agent-message .message-content {
        background: var(--agent-msg);
        border-radius: 1rem 1rem 1rem 0;
        border: 1px solid var(--surface);
    }
    
    .message-content {
        padding: 0.5rem 1rem;
        line-height: 1.5;
        word-wrap: break-word;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }
    
    .message-content pre {
        background: #000;
        padding: 1rem;
        border-radius: 0.5rem;
        overflow-x: auto;
    }
    .message-content code {
        font-family: monospace;
    }

    .thinking-message .message-content {
        animation: pulse 1.5s infinite;
        opacity: 0.7;
    }

    .message-content table {
        border-collapse: collapse;
        width: 100%;
        margin-top: 1rem;
        margin-bottom: 1rem;
    }
    .message-content th, .message-content td {
        border: 1px solid var(--text-secondary);
        padding: 0.5rem;
        text-align: left;
    }
    .message-content th {
        background-color: rgba(255, 255, 255, 0.1);
        font-weight: 600;
    }

    @@keyframes pulse {
        0% { opacity: 0.5; }
        50% { opacity: 1; }
        100% { opacity: 0.5; }
    }

    .chat-input-area {
        display: flex;
        gap: 0.5rem;
        align-items: flex-end;
        background: var(--surface);
        padding: 0.75rem;
        border-radius: 1rem;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        margin-bottom: 1rem;
    }

    textarea {
        flex: 1;
        background: transparent;
        border: none;
        color: var(--text-primary);
        resize: none;
        padding: 0.5rem;
        font-family: inherit;
        font-size: 1rem;
        line-height: 1.5;
        max-height: 150px;
    }
    textarea:focus { outline: none; }

    button {
        background: var(--primary);
        color: white;
        border: none;
        border-radius: 50%;
        width: 44px;
        height: 44px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: transform 0.2s, background 0.2s;
        flex-shrink: 0;
    }
    button:hover:not(:disabled) {
        transform: scale(1.05);
        background: var(--user-msg);
    }
    button:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }
</style>

@code {
    private AIAgent _agent = null!;
    private AgentSession _session = null!;
    private string currentInput = "";
    private bool isThinking = false;
    private ElementReference chatHistoryRef;
    
    private List<ChatMessage> messages = new();

    private MarkdownPipeline _pipeline = new MarkdownPipelineBuilder().UseAdvancedExtensions().Build();
    
    protected override async Task OnInitializedAsync()
    {
        _agent = AgentFactory.GetAgent("Assistant");
        _session = await _agent.CreateSessionAsync();
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await SendMessage();
        }
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(currentInput) || isThinking)
            return;

        var userText = currentInput;
        currentInput = "";
        
        messages.Add(new ChatMessage { Content = userText, IsUser = true });
        isThinking = true;
        
        await ScrollToBottom();
        StateHasChanged();

        var agentMsg = new ChatMessage { Content = "", IsUser = false };
        messages.Add(agentMsg);

        try
        {
            var firstUpdate = true;
            await foreach (var update in _agent.RunStreamingAsync(userText, _session))
            {
                if (firstUpdate)
                {
                    isThinking = false;
                    firstUpdate = false;
                }
                
                agentMsg.Content += update;

                StateHasChanged();
                await ScrollToBottom();
                
                await Task.Yield(); 
            }
            
            Console.WriteLine(agentMsg.Content);
        }
        catch (Exception ex)
        {
            agentMsg.Content = $"**Error:** {ex.Message}";
            isThinking = false;
            StateHasChanged();
        }
        finally
        {
            isThinking = false;
            StateHasChanged();
            await ScrollToBottom();
        }
    }

    private async Task ScrollToBottom()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("eval", "var chat = document.querySelector('.chat-history'); if(chat) chat.scrollTop = chat.scrollHeight;");
        }
        catch { }
    }

    private class ChatMessage
    {
        public string Content { get; set; } = "";
        public bool IsUser { get; set; }
    }
}