@using Mullai.Web.Wasm.Services
@using Mullai.Abstractions.Orchestration
@inject ChatState ChatState

<div class="chat-input-area">
    <textarea @bind="currentInput" @bind:event="oninput" @onkeydown="HandleKeyDown"
              placeholder="Ask a question..." rows="1"></textarea>
    <button class="send-button" @onclick="SendMessage" disabled="@(string.IsNullOrWhiteSpace(currentInput) || ChatState.IsThinking)">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
    </button>
</div>

@code {
    [Parameter] public ExecutionMode Mode { get; set; } = ExecutionMode.Team;
    private string currentInput = "";

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await SendMessage();
        }
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(currentInput) || ChatState.IsThinking)
            return;

        var text = currentInput;
        currentInput = "";
        await ChatState.SendMessageAsync(text, Mode);
    }
}
