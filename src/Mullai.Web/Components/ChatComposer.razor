@using Mullai.Abstractions.Configuration
@using Mullai.Abstractions.Models
@using Mullai.Web.Models
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject IMullaiConfigurationManager ConfigurationManager

<div class="composer-container">
    <div class="composer-controls">
        <div class="selector-group">
            <span class="selector-label">Provider</span>
            <div class="premium-dropdown provider-dropdown">
                <div class="dropdown-trigger" @onclick="ToggleProviderDropdown">
                    <span class="trigger-text">@_selectedProvider</span>
                    <svg class="chevron @(_showProviderDropdown ? "open" : "")" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2">
                        <path d="M6 9l6 6 6-6"/>
                    </svg>
                </div>
                @if (_showProviderDropdown)
                {
                    <div class="dropdown-menu">
                        <div class="search-container">
                            <input class="search-input"
                                   @bind="_providerSearch"
                                   @bind:event="oninput"
                                   placeholder="Search providers..."
                                   @onclick:stopPropagation="true"
                                   autofocus/>
                        </div>
                        <div class="options-list">
                            @foreach (var provider in FilteredProviders)
                            {
                                <div class="option @(provider.Name == _selectedProvider ? "selected" : "")"
                                     @onclick="() => SelectProvider(provider.Name)">
                                    @provider.Name
                                </div>
                            }
                            @if (!FilteredProviders.Any())
                            {
                                <div class="no-results">No providers found</div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="selector-group">
            <span class="selector-label">Model</span>
            <div class="premium-dropdown model-dropdown">
                <div class="dropdown-trigger @(string.IsNullOrEmpty(_selectedProvider) ? "disabled" : "")"
                     @onclick="ToggleModelDropdown">
                    <span
                        class="trigger-text">@(_availableModels.FirstOrDefault(m => m.ModelId == _selectedModel)?.ModelName ?? "Select Model")</span>
                    <svg class="chevron @(_showModelDropdown ? "open" : "")" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2">
                        <path d="M6 9l6 6 6-6"/>
                    </svg>
                </div>
                @if (_showModelDropdown)
                {
                    <div class="dropdown-menu">
                        <div class="search-container">
                            <input class="search-input"
                                   @bind="_modelSearch"
                                   @bind:event="oninput"
                                   placeholder="Search models..."
                                   @onclick:stopPropagation="true"
                                   autofocus/>
                        </div>
                        <div class="options-list">
                            @foreach (var model in FilteredModels)
                            {
                                <div class="option @(model.ModelId == _selectedModel ? "selected" : "")"
                                     @onclick="() => SelectModel(model.ModelId)">
                                    <div class="option-name">@model.ModelName</div>
                                </div>
                            }
                            @if (!FilteredModels.Any())
                            {
                                <div class="no-results">No models found</div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="selector-group">
            <span class="selector-label">Agent</span>
            <div class="premium-dropdown agent-dropdown">
                <div class="dropdown-trigger" @onclick="ToggleAgentDropdown">
                    <span
                        class="trigger-text">@(_enabledAgents.FirstOrDefault(a => a.Id == _selectedAgent)?.Name ?? "Select Agent")</span>
                    <svg class="chevron @(_showAgentDropdown ? "open" : "")" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2">
                        <path d="M6 9l6 6 6-6"/>
                    </svg>
                </div>
                @if (_showAgentDropdown)
                {
                    <div class="dropdown-menu">
                        <div class="search-container">
                            <input class="search-input"
                                   @bind="_agentSearch"
                                   @bind:event="oninput"
                                   placeholder="Search agents..."
                                   @onclick:stopPropagation="true"
                                   autofocus/>
                        </div>
                        <div class="options-list">
                            @foreach (var agent in FilteredAgents)
                            {
                                <div class="option @(agent.Id == _selectedAgent ? "selected" : "")"
                                     @onclick="() => SelectAgent(agent.Id)">
                                    <div class="option-name">@agent.Name</div>
                                </div>
                            }
                            @if (!FilteredAgents.Any())
                            {
                                <div class="no-results">No agents found</div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>

        @if (InputTokenCount > 0 || OutputTokenCount > 0)
        {
            <div class="usage-stats">
                <div class="usage-item" title="Input tokens">
                    <svg class="usage-icon up" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M17 11l-5-5-5 5M17 18l-5-5-5 5"/>
                    </svg>
                    <span>@InputTokenCount</span>
                </div>
                <div class="usage-item" title="Output tokens">
                    <svg class="usage-icon down" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M7 13l5 5 5-5M7 6l5 5 5-5"/>
                    </svg>
                    <span>@OutputTokenCount</span>
                </div>
                @if (ActiveModel != null)
                {
                    <div class="usage-item context-usage"
                         title="Context Usage: @(ContextUsagePercent.ToString("F1"))% (@(InputTokenCount + OutputTokenCount) / @(ActiveModel.ContextWindow > 0 ? ActiveModel.ContextWindow.ToString() : "Unknown") tokens)">
                        <div class="context-progress-mini">
                            <div class="context-progress-fill"
                                 style="width: @(ContextUsagePercent.ToString("F1"))%; background-color: @GetProgressColor(); --bar-color: @GetProgressColor();"></div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    @if (_showProviderDropdown || _showModelDropdown || _showAgentDropdown)
    {
        <div class="dropdown-overlay" @onclick="CloseDropdowns"></div>
    }

    <div class="composer-box">
        <button class="action-btn" type="button" aria-label="Add attachment">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path
                    d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/>
            </svg>
        </button>

        <textarea @ref="_textAreaRef"
                  class="composer-input"
                  placeholder="Ask Mullai anything..."
                  value="@Value"
                  @oninput="HandleInput"
                  rows="1"
                  spellcheck="false"></textarea>

        <button class="send-btn @(IsEmpty ? "disabled" : "")"
                type="button"
                @onclick="HandleSubmit"
                disabled="@IsEmpty"
                aria-label="Send message">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="22" y1="2" x2="11" y2="13"/>
                <polygon points="22 2 15 22 11 13 2 9 22 2"/>
            </svg>
        </button>
    </div>
    <div class="composer-footer">
        Mullai can make mistakes. Check important info.
    </div>
</div>

@code {
    [Parameter] public string Value { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public EventCallback<ComposerSubmitArgs> OnSubmit { get; set; }
    [Parameter] public string SelectedProvider { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> SelectedProviderChanged { get; set; }
    [Parameter] public string SelectedModel { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> SelectedModelChanged { get; set; }
    [Parameter] public string SelectedAgent { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> SelectedAgentChanged { get; set; }
    [Parameter] public long InputTokenCount { get; set; }
    [Parameter] public long OutputTokenCount { get; set; }

    private List<MullaiProviderDescriptor> _enabledProviders = [];
    private List<MullaiModelDescriptor> _availableModels = [];
    private string _selectedProvider = string.Empty;
    private string _selectedModel = string.Empty;
    private string _selectedAgent = string.Empty;

    private List<AgentDefinition> _enabledAgents = [];
    private string _providerSearch = string.Empty;
    private string _modelSearch = string.Empty;
    private string _agentSearch = string.Empty;
    private bool _showProviderDropdown;
    private bool _showModelDropdown;
    private bool _showAgentDropdown;

    private IEnumerable<MullaiProviderDescriptor> FilteredProviders =>
        string.IsNullOrWhiteSpace(_providerSearch)
            ? _enabledProviders
            : _enabledProviders.Where(p => p.Name.Contains(_providerSearch, StringComparison.OrdinalIgnoreCase));

    private IEnumerable<MullaiModelDescriptor> FilteredModels =>
        string.IsNullOrWhiteSpace(_modelSearch)
            ? _availableModels
            : _availableModels.Where(m => m.ModelName.Contains(_modelSearch, StringComparison.OrdinalIgnoreCase)
                                          || m.ModelId.Contains(_modelSearch, StringComparison.OrdinalIgnoreCase));

    private IEnumerable<AgentDefinition> FilteredAgents =>
        string.IsNullOrWhiteSpace(_agentSearch)
            ? _enabledAgents
            : _enabledAgents.Where(a => a.Name.Contains(_agentSearch, StringComparison.OrdinalIgnoreCase));

    private MullaiModelDescriptor? ActiveModel =>
        _availableModels.FirstOrDefault(m => string.Equals(m.ModelId, _selectedModel, StringComparison.OrdinalIgnoreCase));

    private double ContextUsagePercent
    {
        get
        {
            var model = ActiveModel;
            if (model == null || model.ContextWindow <= 0) return 0;
            var total = InputTokenCount + OutputTokenCount;
            // Cap at 100%
            return Math.Min(100.0, (double)total / model.ContextWindow * 100.0);
        }
    }

    private string GetProgressColor()
    {
        var pct = ContextUsagePercent;
        if (pct < 50) return "var(--accent)";
        if (pct < 85) return "#f59e0b"; // Amber
        return "#ef4444"; // Red
    }

    private ElementReference _textAreaRef;
    private IJSObjectReference? _module;
    private DotNetObjectReference<ChatComposer>? _objRef;

    private bool IsEmpty => string.IsNullOrWhiteSpace(Value);

    protected override void OnInitialized()
    {
        ConfigurationManager.OnConfigurationChanged += HandleConfigurationChanged;
        LoadProvidersAndModels();
    }

    private void HandleConfigurationChanged()
    {
        InvokeAsync(() =>
        {
            LoadProvidersAndModels();
            StateHasChanged();
        });
    }

    private void LoadProvidersAndModels()
    {
        var config = ConfigurationManager.GetProvidersConfig();
        var customProviders = ConfigurationManager.GetCustomProviders();

        _enabledProviders = config.Providers
            .Where(p => p.Enabled && ConfigurationManager.IsProviderEnabled(p.Name, true))
            .Select(p => new MullaiProviderDescriptor
            {
                Name = p.Name,
                Enabled = true,
                Models = p.Models.Where(m => m.Enabled && ConfigurationManager.IsModelEnabled(p.Name, m.ModelId, true)).ToList()
            })
            .Where(p => p.Models.Any())
            .ToList();

        // Add custom providers if they are enabled in Mcp/Custom
        foreach (var custom in customProviders.Where(cp => cp.Enabled && cp.Models.Any()))
        {
            _enabledProviders.Add(new MullaiProviderDescriptor
            {
                Name = custom.Name,
                Enabled = true,
                Models = custom.Models.Select(m => new MullaiModelDescriptor
                {
                    ModelId = m,
                    ModelName = m,
                    Enabled = true
                }).ToList()
            });
        }

        _enabledAgents = ConfigurationManager.GetAgents().Where(a => a.Enabled).ToList();

        if (_enabledProviders.Any())
        {
            // If already have a provider selected, ensure it's still valid
            if (!string.IsNullOrEmpty(_selectedProvider))
            {
                var existing = _enabledProviders.FirstOrDefault(p => p.Name.Equals(_selectedProvider, StringComparison.OrdinalIgnoreCase));
                if (existing != null)
                {
                    _selectedProvider = existing.Name; // Use canonical name
                    UpdateAvailableModels();
                }
                else
                {
                    _selectedProvider = string.Empty;
                }
            }
        }
    }

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrEmpty(SelectedProvider) && SelectedProvider != _selectedProvider)
        {
            _selectedProvider = SelectedProvider;
            UpdateAvailableModels();
        }

        if (!string.IsNullOrEmpty(SelectedModel) && SelectedModel != _selectedModel)
        {
            _selectedModel = SelectedModel;
        }

        if (!string.IsNullOrEmpty(SelectedAgent) && SelectedAgent != _selectedAgent)
        {
            _selectedAgent = SelectedAgent;
        }
    }

    private async Task ToggleProviderDropdown()
    {
        _showProviderDropdown = !_showProviderDropdown;
        if (_showProviderDropdown)
        {
            _showModelDropdown = false;
            _providerSearch = string.Empty;
            await Task.Delay(50);
            if (_module != null) await _module.InvokeVoidAsync("scrollToSelected", ".provider-dropdown .options-list");
        }
    }

    private async Task ToggleModelDropdown()
    {
        if (string.IsNullOrEmpty(_selectedProvider)) return;

        _showModelDropdown = !_showModelDropdown;
        if (_showModelDropdown)
        {
            _showProviderDropdown = false;
            _modelSearch = string.Empty;
            await Task.Delay(50);
            if (_module != null) await _module.InvokeVoidAsync("scrollToSelected", ".model-dropdown .options-list");
        }
    }

    private async Task ToggleAgentDropdown()
    {
        _showAgentDropdown = !_showAgentDropdown;
        if (_showAgentDropdown)
        {
            _showProviderDropdown = false;
            _showModelDropdown = false;
            _agentSearch = string.Empty;
            await Task.Delay(50);
            if (_module != null) await _module.InvokeVoidAsync("scrollToSelected", ".agent-dropdown .options-list");
        }
    }

    private void CloseDropdowns()
    {
        _showProviderDropdown = false;
        _showModelDropdown = false;
        _showAgentDropdown = false;
    }

    private async Task SelectProvider(string name)
    {
        _selectedProvider = name;
        _showProviderDropdown = false;
        UpdateAvailableModels();
        await SelectedProviderChanged.InvokeAsync(name);
        await SelectedModelChanged.InvokeAsync(_selectedModel);
        if (_module != null) await _module.InvokeVoidAsync("saveToLocalStorage", "mullai_last_provider", name);
        if (_module != null) await _module.InvokeVoidAsync("saveToLocalStorage", "mullai_last_model", _selectedModel);
    }

    private async Task SelectModel(string modelId)
    {
        _selectedModel = modelId;
        _showModelDropdown = false;
        await SelectedModelChanged.InvokeAsync(modelId);
        if (_module != null) await _module.InvokeVoidAsync("saveToLocalStorage", "mullai_last_model", modelId);
    }

    private async Task SelectAgent(string agentId)
    {
        _selectedAgent = agentId;
        _showAgentDropdown = false;
        await SelectedAgentChanged.InvokeAsync(agentId);
        if (_module != null) await _module.InvokeVoidAsync("saveToLocalStorage", "mullai_last_agent", agentId);
    }

    private void UpdateAvailableModels()
    {
        var provider = _enabledProviders.FirstOrDefault(p => p.Name == _selectedProvider);
        if (provider != null)
        {
            _availableModels = provider.Models.Where(m => m.Enabled).ToList();
            if (_availableModels.Any())
            {
                if (string.IsNullOrEmpty(_selectedModel) || !_availableModels.Any(m => m.ModelId == _selectedModel))
                {
                    _selectedModel = _availableModels[0].ModelId;
                }
            }
            else
            {
                _selectedModel = string.Empty;
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _module = await JS.InvokeAsync<IJSObjectReference>("import", "./Components/ChatComposer.razor.js");
            _objRef = DotNetObjectReference.Create(this);
            await _module.InvokeVoidAsync("initialize", _textAreaRef, _objRef);

            // Load from LocalStorage
            var savedProvider = await _module.InvokeAsync<string?>("loadFromLocalStorage", "mullai_last_provider");
            var savedModel = await _module.InvokeAsync<string?>("loadFromLocalStorage", "mullai_last_model");

            if (!string.IsNullOrEmpty(savedProvider))
            {
                var provider = _enabledProviders.FirstOrDefault(p => p.Name.Equals(savedProvider, StringComparison.OrdinalIgnoreCase));
                if (provider != null)
                {
                    _selectedProvider = provider.Name;
                    UpdateAvailableModels();

                    if (!string.IsNullOrEmpty(savedModel))
                    {
                        var model = _availableModels.FirstOrDefault(m => m.ModelId.Equals(savedModel, StringComparison.OrdinalIgnoreCase));
                        if (model != null)
                        {
                            _selectedModel = model.ModelId;
                        }
                    }

                    await SelectedProviderChanged.InvokeAsync(_selectedProvider);
                    await SelectedModelChanged.InvokeAsync(_selectedModel);
                }
            }

            var savedAgent = await _module.InvokeAsync<string?>("loadFromLocalStorage", "mullai_last_agent");
            if (!string.IsNullOrEmpty(savedAgent))
            {
                var agent = _enabledAgents.FirstOrDefault(a => a.Id.Equals(savedAgent, StringComparison.OrdinalIgnoreCase));
                if (agent != null)
                {
                    _selectedAgent = agent.Id;
                    await SelectedAgentChanged.InvokeAsync(_selectedAgent);
                }
            }

            if (string.IsNullOrEmpty(_selectedAgent) && _enabledAgents.Any())
            {
                _selectedAgent = _enabledAgents[0].Id;
                await SelectedAgentChanged.InvokeAsync(_selectedAgent);
            }

            // If still no selection, pick defaults
            if (string.IsNullOrEmpty(_selectedProvider) && _enabledProviders.Any())
            {
                _selectedProvider = _enabledProviders[0].Name;
                UpdateAvailableModels();
                await SelectedProviderChanged.InvokeAsync(_selectedProvider);
                await SelectedModelChanged.InvokeAsync(_selectedModel);
            }

            StateHasChanged();
        }
    }

    [JSInvokable]
    public async Task OnEnterPressed()
    {
        await HandleSubmit();
    }

    private async Task HandleInput(ChangeEventArgs e)
    {
        Value = e.Value?.ToString() ?? string.Empty;
        await ValueChanged.InvokeAsync(Value);
    }

    private async Task HandleSubmit()
    {
        if (!IsEmpty)
        {
            var args = new ComposerSubmitArgs
            {
                Prompt = Value,
                Provider = _selectedProvider,
                Model = _selectedModel,
                Agent = _selectedAgent
            };
            await OnSubmit.InvokeAsync(args);
        }
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            ConfigurationManager.OnConfigurationChanged -= HandleConfigurationChanged;
            if (_module is not null) await _module.DisposeAsync();
            _objRef?.Dispose();
        }
        catch (JSDisconnectedException)
        {
        }
    }

}
