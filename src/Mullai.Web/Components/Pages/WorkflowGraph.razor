@page "/workflows/graph"
@rendermode InteractiveServer
@using Mullai.Workflows.Abstractions
@using Mullai.Workflows.Models

@inject IWorkflowRegistry WorkflowRegistry

<PageTitle>Workflow Graph</PageTitle>

<div class="workflow-graph-page">
    <header class="workflow-graph-header">
        <div>
            <h1>Workflow Graph</h1>
            <p class="workflow-graph-subtitle">Triggers and outputs visualized.</p>
        </div>
    </header>

    @if (_graphs.Count == 0)
    {
        <div class="workflow-graph-empty">No workflows available.</div>
    }
    else
    {
        @foreach (var graph in _graphs)
        {
            <section class="workflow-graph-card">
                <div class="workflow-graph-title">@graph.WorkflowId</div>
                <pre class="mermaid">@graph.Mermaid</pre>
            </section>
        }
    }
</div>

@code {
    private readonly List<WorkflowGraphModel> _graphs = [];

    protected override void OnInitialized()
    {
        foreach (var definition in WorkflowRegistry.GetAll())
        {
            _graphs.Add(new WorkflowGraphModel
            {
                WorkflowId = definition.Id,
                Mermaid = BuildMermaid(definition)
            });
        }
    }

    private static string BuildMermaid(WorkflowDefinition definition)
    {
        var lines = new List<string>
        {
            "flowchart LR",
            $"  W[{Escape(definition.Name)}]"
        };

        var triggerIndex = 0;
        foreach (var trigger in definition.Triggers)
        {
            var triggerLabel = $"{trigger.Type}:{(string.IsNullOrWhiteSpace(trigger.Name) ? trigger.Id : trigger.Name)}";
            var triggerNode = $"T{triggerIndex++}";
            lines.Add($"  {triggerNode}(({Escape(triggerLabel)})) --> W");
        }

        var outputIndex = 0;
        foreach (var output in definition.Outputs)
        {
            var outputLabel = $"{output.Type}:{(string.IsNullOrWhiteSpace(output.Target) ? "-" : output.Target)}";
            var outputNode = $"O{outputIndex++}";
            lines.Add($"  W --> {outputNode}[{Escape(outputLabel)}]");
        }

        return string.Join('\n', lines);
    }

    private static string Escape(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return " ";
        }

        return value.Replace("\"", "'");
    }

    private sealed class WorkflowGraphModel
    {
        public string WorkflowId { get; init; } = string.Empty;
        public string Mermaid { get; init; } = string.Empty;
    }
}
