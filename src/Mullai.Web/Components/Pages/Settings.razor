@page "/settings"
@rendermode InteractiveServer
@using Mullai.Abstractions.Configuration
@using Mullai.Abstractions.Models
@using Mullai.Providers

@inject IMullaiConfigurationManager ConfigManager
@inject HttpClient HttpClient

<PageTitle>Settings</PageTitle>

<div class="settings">
    <div class="settings-header">
        <div style="display: flex; align-items: center; gap: 1rem;">
            <button type="button" class="mobile-menu-btn" @onclick="() => Layout?.ToggleSidebar()">
                <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
            </button>
            <h1>Settings</h1>
        </div>
        <p>Configure providers, models, and API keys used by Mullai.</p>
    </div>

    @if (_loading)
    {
        <div class="card">
            <div class="card-body">
                <div class="hint">Loading settings…</div>
            </div>
        </div>
    }
    else
    {
        @if (!string.IsNullOrWhiteSpace(_status))
        {
            <div class="notice @(_statusKind == NoticeKind.Danger ? "notice-danger" : "notice-success")">@_status</div>
        }
        
        <section class="card">
            <div class="card-head">
                <div class="card-title">General Settings</div>
                <div class="card-subtitle">Manage global preferences and common configuration.</div>
            </div>
            <div class="card-body">
                @if (SelectedProvider is not null)
                {
                    var provider = SelectedProvider;
                    var name = provider.Provider.Name;
                    var hasKey = provider.HasApiKey();
                    var masked = provider.GetMaskedApiKey();

                    <div class="credentials-bar">
                        <div class="credentials-bar-main">
                            <div class="credentials-bar-title">@name API Key</div>
                            <div class="credentials-bar-status">
                                <span class="pill @(hasKey ? "pill-ok" : "pill-warn")">@(hasKey ? "Configured" : "Missing")</span>
                                @if (hasKey && masked is not null)
                                {
                                    <span class="mono">@masked</span>
                                }
                            </div>
                        </div>
                        <div class="credentials-bar-actions">
                            @if (!_apiKeyEditMode && !_apiKeyDeleteConfirm)
                            {
                                <button class="btn btn-sm @(hasKey ? "" : "btn-primary")" type="button" @onclick="BeginApiKeyEdit">
                                    @(hasKey ? "Update" : "Set key")
                                </button>
                                @if (hasKey)
                                {
                                    <button class="btn btn-sm" type="button" @onclick="BeginApiKeyDeleteConfirm">Delete</button>
                                }
                            }
                        </div>
                    </div>

                    @if (_apiKeyEditMode)
                    {
                        <div class="key-editor">
                            <div class="key-editor-header">
                                <div class="key-editor-title">Update @name API Key</div>
                                <div class="card-subtitle">Stored locally and never displayed in full.</div>
                            </div>
                            <div class="key-editor-form">
                                <input class="input" type="password" placeholder="Paste @name API key…" @bind="_apiKeyDraft" @bind:event="oninput" />
                                <button class="btn btn-primary" type="button" @onclick="() => SaveApiKey(name)" disabled="@string.IsNullOrWhiteSpace(_apiKeyDraft)">Save</button>
                                <button class="btn" type="button" @onclick="CancelApiKeyEdit">Cancel</button>
                            </div>
                        </div>
                    }

                    @if (_apiKeyDeleteConfirm)
                    {
                        <div class="notice notice-danger">
                            <div class="key-editor-title">Delete API key for @name?</div>
                            <div style="margin-top: 1rem; display: flex; gap: 0.5rem;">
                                <button class="btn btn-primary" style="background:#dc2626" type="button" @onclick="() => ConfirmDeleteApiKey(name)">Confirm Delete</button>
                                <button class="btn" type="button" @onclick="CancelDeleteApiKey">Cancel</button>
                            </div>
                        </div>
                    }
                }

                <div class="settings-split">
                    <div class="panel">
                        <div class="panel-head">
                            <div class="panel-title">Providers</div>
                            <div class="pill">@_providers.Count</div>
                        </div>

                        <div class="list">
                            @foreach (var providerItem in _providers.OrderBy(p => p.Provider.Priority).ThenBy(p => p.Provider.Name))
                            {
                                var selected = string.Equals(providerItem.Provider.Name, _selectedProviderName, StringComparison.OrdinalIgnoreCase);
                                var hasKey = providerItem.HasApiKey();
                                <button type="button" class="list-item @(selected ? "selected" : "")" @onclick="() => SelectProvider(providerItem.Provider.Name)">
                                    <div class="list-item-main">
                                        <div class="list-item-title">@providerItem.Provider.Name</div>
                                        <div class="list-item-sub">
                                            <span class="pill @(hasKey ? "pill-ok" : "pill-warn")">
                                                @(hasKey ? "Key set" : "No key")
                                            </span>
                                            <span class="dot-separator"></span>
                                            @providerItem.Provider.Models.Count models
                                        </div>
                                    </div>
                                    <label class="toggle" @onclick:stopPropagation="true">
                                        <input type="checkbox"
                                               checked="@providerItem.Enabled"
                                               @onclick:stopPropagation="true"
                                               @onchange="e => OnProviderToggleChanged(providerItem, e)" />
                                        <span class="toggle-ui"></span>
                                    </label>
                                </button>
                            }
                        </div>
                    </div>

                    <div class="panel">
                        @if (SelectedProvider is null)
                        {
                            <div class="panel-empty">
                                <div class="card-title">Select a provider</div>
                                <p class="card-subtitle">Choose a provider on the left to manage its API key and models.</p>
                            </div>
                        }
                        else
                        {
                            var provider = SelectedProvider;
                            <div class="panel-head">
                                <div class="panel-title">Models</div>
                                <div class="panel-actions">
                                    <button class="btn btn-sm" type="button" @onclick="() => RefreshModelsAsync(provider)" disabled="@provider.IsRefreshing">
                                        @(provider.IsRefreshing ? "Refreshing…" : "Refresh")
                                    </button>
                                    <button class="btn btn-sm" type="button" @onclick="() => SetAllModelsEnabledAsync(provider, true)" disabled="@provider.IsBulkUpdating">
                                        Enable all
                                    </button>
                                    <button class="btn btn-sm" type="button" @onclick="() => SetAllModelsEnabledAsync(provider, false)" disabled="@provider.IsBulkUpdating">
                                        Disable all
                                    </button>
                                    <button class="btn btn-sm btn-primary" type="button" @onclick="ToggleModelAddForm">
                                        Add model
                                    </button>
                                </div>
                            </div>

                            <div class="panel-toolbar">
                                <input class="input" placeholder="Search models…" @bind="_modelNameFilter" @bind:event="oninput" />
                                <button type="button" class="btn btn-sm @(_showEnabledModelsOnly ? "btn-on" : "")" @onclick="ToggleEnabledOnly">
                                    Enabled only
                                </button>
                            </div>

                            @if (_showModelAddForm)
                            {
                                <div class="panel-toolbar" style="background: var(--surface-2); border-top: 1px solid var(--border); padding-top: 0.5rem; padding-bottom: 0.5rem;">
                                    <input class="input" placeholder="Model ID (e.g. gpt-4o)" @bind="_newModelId" @bind:event="oninput" style="flex: 1;" />
                                    <input class="input" placeholder="Display Name (optional)" @bind="_newModelName" @bind:event="oninput" style="flex: 1;" />
                                    <button class="btn btn-sm btn-primary" type="button" @onclick="() => AddModel(provider)" disabled="@string.IsNullOrWhiteSpace(_newModelId)">
                                        Save
                                    </button>
                                    <button class="btn btn-sm" type="button" @onclick="ToggleModelAddForm">
                                        Cancel
                                    </button>
                                </div>
                            }

                            @if (!string.IsNullOrWhiteSpace(provider.RefreshError))
                            {
                                <div class="notice notice-danger" style="margin: 1rem;">@provider.RefreshError</div>
                            }

                            <div class="models-scroll">
                                <table>
                                    <thead>
                                    <tr>
                                        <th style="width: 60px;">On</th>
                                        <th>Model Info</th>
                                        <th class="text-right">Context</th>
                                        <th class="text-right">Pricing /M tokens (Inpt/Out)</th>
                                    </tr>
                                    </thead>
                                    <tbody>
                                    @foreach (var model in FilterModels(provider))
                                    {
                                        var enabled = provider.GetModelEnabled(model);
                                        <tr>
                                            <td>
                                                <label class="toggle">
                                                    <input type="checkbox"
                                                           checked="@enabled"
                                                           @onchange="e => OnModelToggleChanged(provider, model, e)" />
                                                    <span class="toggle-ui"></span>
                                                </label>
                                            </td>
                                            <td>
                                                <div class="model-name">@model.ModelName</div>
                                                <div class="model-sub">@model.ModelId</div>
                                            </td>
                                            <td class="mono text-right">
                                                @((model.ContextWindow > 0) ? model.ContextWindow.ToString("N0") : "—")
                                            </td>
                                            <td class="mono text-right">
                                                @FormatPricing(model.Pricing)
                                            </td>
                                        </tr>
                                    }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </section>

        <section class="card" style="margin-top: 2rem;">
            <div class="card-head" style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem; padding: 1.5rem;">
                <div style="flex: 1; min-width: 200px;">
                    <div class="card-title">MCP Servers</div>
                    <div class="card-subtitle" style="margin-top: 0.25rem;">Manage Model Context Protocol (MCP) servers to provide additional tools to Mullai.</div>
                </div>
                <div class="panel-actions">
                    <button class="btn btn-sm btn-primary" type="button" @onclick="ToggleMcpAddForm">
                        @(_showMcpAddForm ? "Cancel" : "Add MCP Server")
                    </button>
                </div>
            </div>
            <div class="card-body">
                @if (_showMcpAddForm)
                {
                    <div class="key-editor" style="margin-bottom: 2rem; border: 1px solid var(--border); padding: 1.5rem; border-radius: 8px;">
                        <div class="key-editor-header">
                            <div class="key-editor-title">@(_editingMcpName == null ? "Add New" : "Edit") MCP Server</div>
                        </div>
                        <div class="key-editor-form" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                            <div class="form-group">
                                <label class="label">Server Name</label>
                                <input class="input" placeholder="e.g. MyLocalTools" @bind="_mcpNameDraft" />
                            </div>
                            <div class="form-group">
                                <label class="label">Connection Type</label>
                                <select class="input" @bind="_mcpTypeDraft">
                                    <option value="stdio">stdio (Local Command)</option>
                                    <option value="sse">sse (Remote URL)</option>
                                </select>
                            </div>
                            @if (_mcpTypeDraft == "stdio")
                            {
                                <div class="form-group" style="grid-column: span 2;">
                                    <label class="label">Executable Command</label>
                                    <input class="input" placeholder="e.g. node, python, /path/to/binary" @bind="_mcpCommandDraft" />
                                </div>
                                <div class="form-group" style="grid-column: span 2;">
                                    <label class="label">Arguments (comma separated)</label>
                                    <input class="input" placeholder="e.g. server.js, --quiet" @bind="_mcpArgsDraft" />
                                </div>
                            }
                            else
                            {
                                <div class="form-group" style="grid-column: span 2;">
                                    <label class="label">Server URL</label>
                                    <input class="input" placeholder="https://example.com/mcp" @bind="_mcpUrlDraft" />
                                </div>
                            }
                            <div style="grid-column: span 2; display: flex; gap: 0.5rem; margin-top: 1rem;">
                                <button class="btn btn-primary" type="button" @onclick="SaveMcpServer" disabled="@string.IsNullOrWhiteSpace(_mcpNameDraft)">Save Server</button>
                                <button class="btn" type="button" @onclick="ToggleMcpAddForm">Cancel</button>
                            </div>
                        </div>
                    </div>
                }

                @if (_mcpConfig.Servers.Count == 0)
                {
                    <div class="panel-empty">
                        <p class="card-subtitle">No MCP servers configured. Add one to extend Mullai's capabilities.</p>
                    </div>
                }
                else
                {
                    <div class="models-scroll" style="max-height: none;">
                        <table>
                            <thead>
                                <tr>
                                    <th style="width: 60px;">On</th>
                                    <th>Server</th>
                                    <th>Type</th>
                                    <th>Details</th>
                                    <th class="text-right">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    var builtInServers = _mcpConfig.Servers.Where(s => s.IsBuiltIn).OrderBy(s => s.Name);
                                    var customServers = _mcpConfig.Servers.Where(s => !s.IsBuiltIn).OrderBy(s => s.Name);
                                }

                                @if (builtInServers.Any())
                                {
                                    <tr class="table-group-header">
                                        <td colspan="5" style="background: var(--surface-2); padding: 0.5rem 1rem; font-weight: 600; font-size: 0.75rem; text-transform: uppercase; color: var(--text-2);">Default Toolkits</td>
                                    </tr>
                                    @foreach (var server in builtInServers)
                                    {
                                        <tr>
                                            <td>
                                                <label class="toggle">
                                                    <input type="checkbox"
                                                           checked="@server.Enabled"
                                                           @onchange="e => OnMcpToggleChanged(server, e)" />
                                                    <span class="toggle-ui"></span>
                                                </label>
                                            </td>
                                            <td>
                                                <div class="model-name" style="display: flex; align-items: center; gap: 0.5rem;">
                                                    @server.Name 
                                                    <span class="pill pill-built-in" style="font-size: 0.65rem; background: var(--surface-3);">Built-in</span>
                                                    @if (server.Requirements.Any() && !IsMcpConfigured(server))
                                                    {
                                                        <span class="pill pill-warning" 
                                                              @onclick="() => ToggleMcpConfig(server.Name)"
                                                              style="font-size: 0.65rem; background: rgba(255, 171, 0, 0.1); color: #ffab00; border: 1px solid rgba(255, 171, 0, 0.2); cursor: pointer;"
                                                              title="Click to configure">Missing Key</span>
                                                    }

                                                    @if (server.Requirements.Any())
                                                    {
                                                        <button class="btn btn-icon btn-sm mcp-config-toggle @(_expandedMcpServers.Contains(server.Name) ? "active" : "")" 
                                                                type="button" 
                                                                @onclick="() => ToggleMcpConfig(server.Name)" 
                                                                style="padding: 2px; margin-left: 4px; border: none; background: transparent; transition: transform 0.2s;"
                                                                title="Configure toolkit settings">
                                                            <svg style="width: 1rem; height: 1rem; color: @(_expandedMcpServers.Contains(server.Name) ? "var(--accent)" : "var(--text-3)"); transform: @(_expandedMcpServers.Contains(server.Name) ? "rotate(45deg)" : "none");" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 15a3 3 0 100-6 3 3 0 000 6z"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1-1.51V21a2 2 0 01-2 2 2 2 0 01-2-2v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83 0 2 2 0 010-2.83l.06-.06a1.65 1.65 0 00.33-1.82 1.65 1.65 0 00-1.51-1H3a2 2 0 01-2-2 2 2 0 012-2h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 010-2.83 2 2 0 012.83 0l.06.06a1.65 1.65 0 001.82.33H9a1.65 1.65 0 001-1.51V3a2 2 0 012-2 2 2 0 012 2v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 0 2 2 0 010 2.83l-.06.06a1.65 1.65 0 00-.33 1.82V9a1.65 1.65 0 001.51 1H21a2 2 0 012 2 2 2 0 01-2 2h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
                                                        </button>
                                                    }
                                                </div>
                                            </td>
                                            <td>
                                                <span class="pill">@server.Type</span>
                                            </td>
                                            <td class="mono" style="font-size: 0.85rem; max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                                @if (server.Type == "stdio")
                                                {
                                                    <span>@server.Command @(string.Join(" ", server.Args))</span>
                                                }
                                                else
                                                {
                                                    <span>@server.Url</span>
                                                }
                                            </td>
                                            <td class="text-right">
                                                <span class="hint" style="font-size: 0.75rem;">Managed by system</span>
                                            </td>
                                        </tr>

                                        @if (server.Requirements.Any() && _expandedMcpServers.Contains(server.Name))
                                        {

                                            <tr class="mcp-config-row">
                                                <td></td>
                                                <td colspan="4">
                                                    <div class="mcp-config-card" style="margin: 0.5rem 0 1rem 0; background: var(--surface-2); border-radius: 12px; border: 1px solid var(--border); overflow: hidden; box-shadow: var(--shadow-sm);">
                                                        <div class="mcp-config-header" style="background: var(--surface-3); padding: 0.75rem 1rem; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between;">
                                                            <div style="display: flex; align-items: center; gap: 0.5rem;">
                                                                <svg style="width: 0.9rem; height: 0.9rem; color: var(--accent);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 15a3 3 0 100-6 3 3 0 000 6z"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-2 2 2 2 0 01-2-2v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83 0 2 2 0 010-2.83l.06-.06a1.65 1.65 0 00.33-1.82 1.65 1.65 0 00-1.51-1H3a2 2 0 01-2-2 2 2 0 012-2h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 010-2.83 2 2 0 012.83 0l.06.06a1.65 1.65 0 001.82.33H9a1.65 1.65 0 001-1.51V3a2 2 0 012-2 2 2 0 012 2v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 0 2 2 0 010 2.83l-.06.06a1.65 1.65 0 00-.33 1.82V9a1.65 1.65 0 001.51 1H21a2 2 0 012 2 2 2 0 01-2 2h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
                                                                <span style="font-size: 0.75rem; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase;">Toolkit Configuration</span>
                                                            </div>
                                                            <div class="hint" style="font-size: 0.65rem;">Changes take effect immediately</div>
                                                        </div>
                                                        <div class="mcp-config-body" style="padding: 1.25rem;">
                                                            @foreach (var req in server.Requirements)
                                                            {
                                                                <div class="mcp-config-field" style="margin-bottom: 1.25rem; last-child: margin-bottom: 0;">
                                                                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
                                                                        <div style="display: flex; align-items: center; gap: 0.5rem;">
                                                                            <label style="font-size: 0.8rem; font-weight: 600; color: var(--text-2);">@req.Description</label>
                                                                            @if (!string.IsNullOrEmpty(req.HelpUrl))
                                                                            {
                                                                                <a href="@req.HelpUrl" target="_blank" title="Where do I find this?" style="color: var(--accent); display: flex; align-items: center;">
                                                                                    <svg style="width: 0.8rem; height: 0.8rem;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg>
                                                                                </a>
                                                                            }
                                                                        </div>
                                                                        @if (req.IsSecret && !string.IsNullOrEmpty(GetMcpSecret(req.Key)))
                                                                        {
                                                                            <span class="pill pill-success" style="font-size: 0.65rem;">Configured</span>
                                                                        }
                                                                    </div>

                                                                    <div style="position: relative; display: flex; gap: 0.5rem;">
                                                                        <input type="@(req.IsSecret ? "password" : "text")" 
                                                                               class="form-input" 
                                                                               style="flex: 1; padding: 0.6rem 1rem; border-radius: 8px; font-family: var(--font-mono); font-size: 0.85rem;"
                                                                               placeholder="@(req.IsSecret ? "Enter secret key..." : "Enter value...")"
                                                                               value="@GetMcpSecret(req.Key)" 
                                                                               @onchange="e => SaveMcpSecret(req.Key, e.Value?.ToString())" />
                                                                        @if (!string.IsNullOrEmpty(GetMcpSecret(req.Key)))
                                                                        {
                                                                            <button class="btn btn-icon btn-sm" @onclick="() => SaveMcpSecret(req.Key, string.Empty)" title="Clear value" style="color: var(--text-3); font-size: 0.7rem; border: none; background: transparent;">✕</button>
                                                                        }
                                                                    </div>
                                                                </div>
                                                            }
                                                        </div>
                                                    </div>
                                                </td>
                                            </tr>
                                        }

                                    }
                                }

                                @if (customServers.Any())
                                {
                                    <tr class="table-group-header">
                                        <td colspan="5" style="background: var(--surface-2); padding: 0.5rem 1rem; font-weight: 600; font-size: 0.75rem; text-transform: uppercase; color: var(--text-2); border-top: 1px solid var(--border);">Custom Servers</td>
                                    </tr>
                                    @foreach (var server in customServers)
                                    {
                                        <tr>
                                            <td>
                                                <label class="toggle">
                                                    <input type="checkbox"
                                                           checked="@server.Enabled"
                                                           @onchange="e => OnMcpToggleChanged(server, e)" />
                                                    <span class="toggle-ui"></span>
                                                </label>
                                            </td>
                                            <td>
                                                <div class="model-name">@server.Name</div>
                                            </td>
                                            <td>
                                                <span class="pill">@server.Type</span>
                                            </td>
                                            <td class="mono" style="font-size: 0.85rem; max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                                @if (server.Type == "stdio")
                                                {
                                                    <span>@server.Command @(string.Join(" ", server.Args))</span>
                                                }
                                                else
                                                {
                                                    <span>@server.Url</span>
                                                }
                                            </td>
                                            <td class="text-right">
                                                <button class="btn btn-sm" type="button" @onclick="() => EditMcpServer(server)">Edit</button>
                                                <button class="btn btn-sm" style="color: #dc2626" type="button" @onclick="() => DeleteMcpServer(server.Name)">Delete</button>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                }

            </div>
        </section>
    }
</div>

@code {
    [CascadingParameter] public Layout.MainLayout? Layout { get; set; }

    private bool _loading = true;
    private string? _status;
    private NoticeKind _statusKind = NoticeKind.Success;

    private MullaiProvidersConfig _providersConfig = new();
    private List<ProviderVm> _providers = [];

    private string _apiKeyDraft = string.Empty;
    private bool _apiKeyEditMode;
    private bool _apiKeyDeleteConfirm;

    private string? _selectedProviderName;
    private string _modelNameFilter = string.Empty;
    private bool _showEnabledModelsOnly;
    
    private bool _showModelAddForm;
    private string _newModelId = string.Empty;
    private string _newModelName = string.Empty;

    private McpConfiguration _mcpConfig = new();
    private readonly HashSet<string> _expandedMcpServers = new(StringComparer.OrdinalIgnoreCase);
    private bool _showMcpAddForm;
    private string? _editingMcpName;
    private string _mcpNameDraft = string.Empty;
    private string _mcpTypeDraft = "stdio";
    private string _mcpCommandDraft = string.Empty;
    private string _mcpArgsDraft = string.Empty;
    private string _mcpUrlDraft = string.Empty;

    protected override void OnInitialized()
    {
        LoadAll();
    }

    private void LoadAll()
    {
        _providersConfig = ConfigManager.GetProvidersConfig();
        _providers = _providersConfig.Providers.Select(p => new ProviderVm(p, ConfigManager)).ToList();
        _mcpConfig = ConfigManager.GetMcpConfiguration();

        _selectedProviderName ??= _providers.OrderBy(p => p.Provider.Priority).ThenBy(p => p.Provider.Name).FirstOrDefault()?.Provider.Name;
        _loading = false;
    }

    private async Task RefreshModelsAsync(ProviderVm provider)
    {
        provider.IsRefreshing = true;
        provider.RefreshError = null;
        _status = null;
        StateHasChanged();

        try
        {
            var apiKey = ConfigManager.GetApiKey(provider.Provider.Name);
            var models = await MullaiChatClientFactory.GetModelsForProviderAsync(provider.Provider.Name, HttpClient, apiKey);
            provider.Provider.Models = models;
            ConfigManager.SaveProvidersConfig(_providersConfig);
            SetStatus($"Fetched {models.Count} models for {provider.Provider.Name}.", NoticeKind.Success);
        }
        catch (Exception ex)
        {
            provider.RefreshError = ex.Message;
        }
        finally
        {
            provider.IsRefreshing = false;
            StateHasChanged();
        }
    }

    private void CancelApiKeyEdit()
    {
        _apiKeyEditMode = false;
        _apiKeyDeleteConfirm = false;
        _apiKeyDraft = string.Empty;
    }

    private void SaveApiKey(string providerName)
    {
        if (string.IsNullOrWhiteSpace(_apiKeyDraft))
        {
            return;
        }

        ConfigManager.SaveApiKey(providerName, _apiKeyDraft.Trim());
        CancelApiKeyEdit();
        _providers = _providersConfig.Providers.Select(p => new ProviderVm(p, ConfigManager)).ToList();
        SetStatus($"Saved API key for {providerName}.", NoticeKind.Success);
    }

    private static string FormatPricing(ModelPricing? pricing)
    {
        if (pricing is null)
        {
            return "—";
        }

        return $"{pricing.InputPer1kTokens:F6}/{pricing.OutputPer1kTokens:F6}";
    }

    private void SetStatus(string message, NoticeKind kind)
    {
        _status = message;
        _statusKind = kind;
    }

    private enum NoticeKind
    {
        Success,
        Danger
    }

    private sealed class ProviderVm
    {
        private readonly IMullaiConfigurationManager _config;
        private readonly Dictionary<string, bool> _modelEnabled = new(StringComparer.OrdinalIgnoreCase);

        public ProviderVm(MullaiProviderDescriptor provider, IMullaiConfigurationManager config)
        {
            Provider = provider;
            _config = config;
            Enabled = _config.IsProviderEnabled(provider.Name, provider.Enabled);

            foreach (var model in provider.Models)
            {
                _modelEnabled[model.ModelId] = _config.IsModelEnabled(provider.Name, model.ModelId, model.Enabled);
            }
        }

        public MullaiProviderDescriptor Provider { get; }
        public bool Enabled { get; set; }

        public bool IsRefreshing { get; set; }
        public string? RefreshError { get; set; }
        public bool IsBulkUpdating { get; set; }

        public bool GetModelEnabled(MullaiModelDescriptor model)
        {
            if (_modelEnabled.TryGetValue(model.ModelId, out var enabled))
            {
                return enabled;
            }

            enabled = _config.IsModelEnabled(Provider.Name, model.ModelId, model.Enabled);
            _modelEnabled[model.ModelId] = enabled;
            return enabled;
        }

        public void SetModelEnabled(MullaiModelDescriptor model, bool enabled)
            => _modelEnabled[model.ModelId] = enabled;

        public string? GetMaskedApiKey()
        {
            var key = _config.GetApiKey(Provider.Name);
            if (string.IsNullOrWhiteSpace(key))
            {
                return null;
            }

            return key.Length > 10 ? $"{key[..4]}…{key[^4..]}" : "Set";
        }

        public bool HasApiKey()
            => !string.IsNullOrWhiteSpace(_config.GetApiKey(Provider.Name));
    }

    private ProviderVm? SelectedProvider
        => string.IsNullOrWhiteSpace(_selectedProviderName)
            ? null
            : _providers.FirstOrDefault(p => string.Equals(p.Provider.Name, _selectedProviderName, StringComparison.OrdinalIgnoreCase));

    private void SelectProvider(string providerName)
    {
        _selectedProviderName = providerName;
        _modelNameFilter = string.Empty;
        _showEnabledModelsOnly = false;
        _status = null;
        CancelApiKeyEdit();
    }

    private void ToggleEnabledOnly()
        => _showEnabledModelsOnly = !_showEnabledModelsOnly;

    private IEnumerable<MullaiModelDescriptor> FilterModels(ProviderVm provider)
    {
        IEnumerable<MullaiModelDescriptor> models = provider.Provider.Models;

        var filter = _modelNameFilter.Trim();
        if (!string.IsNullOrWhiteSpace(filter))
        {
            models = models.Where(m =>
                m.ModelName.Contains(filter, StringComparison.OrdinalIgnoreCase) ||
                m.ModelId.Contains(filter, StringComparison.OrdinalIgnoreCase));
        }

        if (_showEnabledModelsOnly)
        {
            models = models.Where(m => provider.GetModelEnabled(m));
        }

        return models;
    }

    private void OnProviderToggleChanged(ProviderVm provider, ChangeEventArgs e)
    {
        var enabled = ParseCheckbox(e.Value);
        provider.Enabled = enabled;
        ConfigManager.SetProviderEnabled(provider.Provider.Name, enabled);
        SetStatus($"{provider.Provider.Name} {(enabled ? "enabled" : "disabled")}.", NoticeKind.Success);
    }

    private void OnModelToggleChanged(ProviderVm provider, MullaiModelDescriptor model, ChangeEventArgs e)
    {
        var enabled = ParseCheckbox(e.Value);
        provider.SetModelEnabled(model, enabled);
        ConfigManager.SetModelEnabled(provider.Provider.Name, model.ModelId, enabled);
        SetStatus($"{model.ModelName} {(enabled ? "enabled" : "disabled")}.", NoticeKind.Success);
    }

    private async Task SetAllModelsEnabledAsync(ProviderVm provider, bool enabled)
    {
        provider.IsBulkUpdating = true;
        _status = null;
        StateHasChanged();

        try
        {
            foreach (var model in provider.Provider.Models)
            {
                provider.SetModelEnabled(model, enabled);
                ConfigManager.SetModelEnabled(provider.Provider.Name, model.ModelId, enabled);
            }

            SetStatus($"{provider.Provider.Name}: {(enabled ? "enabled" : "disabled")} all models.", NoticeKind.Success);
        }
        finally
        {
            provider.IsBulkUpdating = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void ToggleModelAddForm()
    {
        _showModelAddForm = !_showModelAddForm;
        _newModelId = string.Empty;
        _newModelName = string.Empty;
    }

    private void AddModel(ProviderVm provider)
    {
        if (string.IsNullOrWhiteSpace(_newModelId)) return;

        var model = new MullaiModelDescriptor
        {
            ModelId = _newModelId.Trim(),
            ModelName = string.IsNullOrWhiteSpace(_newModelName) ? _newModelId.Trim() : _newModelName.Trim(),
            Enabled = true
        };

        ConfigManager.AddModelDescriptor(provider.Provider.Name, model);
        LoadAll(); // To refresh UI
        
        SetStatus($"Added model {model.ModelName} to {provider.Provider.Name}.", NoticeKind.Success);
        
        _showModelAddForm = false;
        _newModelId = string.Empty;
        _newModelName = string.Empty;
    }

    private void BeginApiKeyEdit()
    {
        _apiKeyDeleteConfirm = false;
        _apiKeyEditMode = true;
        _apiKeyDraft = string.Empty;
    }

    private void BeginApiKeyDeleteConfirm()
    {
        _apiKeyEditMode = false;
        _apiKeyDeleteConfirm = true;
        _apiKeyDraft = string.Empty;
    }

    private void CancelDeleteApiKey()
        => _apiKeyDeleteConfirm = false;

    private void ConfirmDeleteApiKey(string providerName)
    {
        ConfigManager.DeleteApiKey(providerName);
        _providers = _providersConfig.Providers.Select(p => new ProviderVm(p, ConfigManager)).ToList();
        CancelApiKeyEdit();
        SetStatus($"Deleted API key for {providerName}.", NoticeKind.Success);
    }

    private void ToggleMcpAddForm()
    {
        _showMcpAddForm = !_showMcpAddForm;
        if (!_showMcpAddForm)
        {
            _editingMcpName = null;
            ResetMcpDrafts();
        }
    }

    private void ResetMcpDrafts()
    {
        _mcpNameDraft = "";
        _mcpTypeDraft = "stdio";
        _mcpCommandDraft = "";
        _mcpArgsDraft = "";
        _mcpUrlDraft = "";
    }

    private void EditMcpServer(McpServerDescriptor server)
    {
        _editingMcpName = server.Name;
        _mcpNameDraft = server.Name;
        _mcpTypeDraft = server.Type;
        _mcpCommandDraft = server.Command;
        _mcpArgsDraft = string.Join(", ", server.Args);
        _mcpUrlDraft = server.Url;
        _showMcpAddForm = true;
    }

    private void SaveMcpServer()
    {
        if (string.IsNullOrWhiteSpace(_mcpNameDraft)) return;

        var server = _mcpConfig.Servers.FirstOrDefault(s => s.Name.Equals(_editingMcpName ?? _mcpNameDraft, StringComparison.OrdinalIgnoreCase));
        if (server == null)
        {
            server = new McpServerDescriptor { Name = _mcpNameDraft };
            _mcpConfig.Servers.Add(server);
        }

        server.Name = _mcpNameDraft;
        server.Type = _mcpTypeDraft;
        server.Command = _mcpCommandDraft;
        server.Args = _mcpArgsDraft.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        server.Url = _mcpUrlDraft;

        ConfigManager.SaveMcpConfiguration(_mcpConfig);
        SetStatus($"Saved MCP server {server.Name}.", NoticeKind.Success);
        
        _showMcpAddForm = false;
        _editingMcpName = null;
        ResetMcpDrafts();
    }

    private void DeleteMcpServer(string name)
    {
        ConfigManager.DeleteMcpServer(name);
        _mcpConfig = ConfigManager.GetMcpConfiguration();
        SetStatus($"Deleted MCP server {name}.", NoticeKind.Success);
    }

    private void OnMcpToggleChanged(McpServerDescriptor server, ChangeEventArgs e)
    {
        server.Enabled = ParseCheckbox(e.Value);
        ConfigManager.SaveMcpConfiguration(_mcpConfig);
        SetStatus($"{server.Name} {(server.Enabled ? "enabled" : "disabled")}.", NoticeKind.Success);
    }

    private void ToggleMcpConfig(string name)
    {
        if (!_expandedMcpServers.Remove(name))
        {
            _expandedMcpServers.Add(name);
        }
    }

    private string GetMcpSecret(string key) => ConfigManager.GetMcpSecret(key) ?? string.Empty;

    private bool IsMcpConfigured(McpServerDescriptor server)
    {
        return server.Requirements.All(r => !string.IsNullOrEmpty(ConfigManager.GetMcpSecret(r.Key)));
    }

    private void SaveMcpSecret(string key, string? value)

    {
        if (value != null)
        {
            ConfigManager.SaveMcpSecret(key, value);
            SetStatus($"Saved configuration for {key}.", NoticeKind.Success);
        }
    }


    private static bool ParseCheckbox(object? value)
        => value switch
        {
            bool b => b,
            string s when bool.TryParse(s, out var b) => b,
            _ => false
        };
}
