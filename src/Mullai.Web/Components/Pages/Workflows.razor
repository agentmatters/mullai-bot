@page "/workflows"
@page "/workflows/{SelectedWorkflowId}"
@rendermode InteractiveServer
@using System.Text
@using System.Text.Json
@using Microsoft.Extensions.Options
@using Mullai.Abstractions.WorkflowState
@using Mullai.TaskRuntime.Abstractions
@using Mullai.TaskRuntime.Models
@using Mullai.TaskRuntime.Options
@using Mullai.Tools.WorkflowTool
@using Mullai.Web.Components.Workflows
@using Mullai.Workflows.Abstractions
@using Mullai.Workflows.Models
@implements IAsyncDisposable

@inject IWorkflowRegistry WorkflowRegistry
@inject IMullaiTaskQueue TaskQueue
@inject IMullaiTaskStatusStore StatusStore
@inject IMullaiTaskResponseChannel ResponseChannel
@inject IOptions<MullaiTaskRuntimeOptions> RuntimeOptions
@inject HttpClient Http
@inject NavigationManager Nav
@inject WorkflowTool WorkflowTool
@inject IWorkflowStateStore WorkflowStateStore

<PageTitle>Workflows</PageTitle>

<div class="workflows-dashboard">
    <WorkflowSidebar
        Workflows="@_definitions"
        SelectedWorkflowId="@SelectedWorkflowId"
        OnWorkflowSelected="HandleWorkflowSelected"
        WorkflowStatuses="@_workflowStatuses"/>

    <main class="workflow-main">
        @if (SelectedWorkflowId == null)
        {
            <div class="workflow-empty-state">
                <div class="empty-icon">📂</div>
                <h2>Select a Workflow</h2>
                <p>Choose a workflow from the sidebar to view details, run agents, or monitor history.</p>
            </div>
        }
        else if (_selectedState != null)
        {
            <header class="workflow-detail-header">
                <div class="header-info">
                    <h1>@_selectedState.Definition.Name</h1>
                    <p>@_selectedState.Definition.Description</p>
                </div>
                <div class="header-meta">
                    <span class="kind-badge">@_selectedState.Definition.Kind</span>
                    <label class="workflow-toggle">
                        <input type="checkbox"
                               checked="@_selectedState.Definition.IsEnabled"
                               @onchange="async _ => await ToggleWorkflowAsync(_selectedState)"/>
                        <span>@(_selectedState.Definition.IsEnabled ? "On" : "Off")</span>
                    </label>
                </div>
            </header>

            <WorkflowTabs ActiveTab="@_activeTab" OnTabChanged="tab => _activeTab = tab"/>

            <div class="workflow-content">
                @if (_activeTab == "Execution")
                {
                    <WorkflowExecutionView
                        @bind-Input="_selectedState.Input"
                        IsRunning="@_selectedState.IsRunning"
                        Status="@_selectedState.Status"
                        Response="@_selectedState.Response"
                        Error="@_selectedState.Error"
                        IsEnabled="@_selectedState.Definition.IsEnabled"
                        OnRunClicked="() => RunWorkflowAsync(_selectedState)"/>
                }
                else if (_activeTab == "Visual Graph")
                {
                    <WorkflowGraphView Definition="@_selectedState.Definition"/>
                }
                else if (_activeTab == "History")
                {
                    <WorkflowRunsView Runs="@_selectedState.RecentRuns" OnLoadDetails="LoadRunDetailsAsync"/>
                }
                else if (_activeTab == "Triggers")
                {
                    <WorkflowTriggersView
                        Triggers="@_selectedState.WebhookTriggers"
                        OnSendWebhook="trigger => SendWebhookAsync(_selectedState, trigger)"/>
                }
                else if (_activeTab == "State")
                {
                    <WorkflowStateView
                        Entries="@_selectedState.StateEntries"
                        OnSave="entry => SaveStateAsync(_selectedState, entry)"
                        OnDelete="entry => DeleteStateAsync(_selectedState, entry)"
                        OnReload="() => RefreshStateAsync(_selectedState)"/>
                }
            </div>
        }
    </main>
</div>

@code {
    [Parameter] public string? SelectedWorkflowId { get; set; }

    private List<WorkflowDefinition> _definitions = [];
    private readonly Dictionary<string, WorkflowCardState> _states = new();
    private readonly Dictionary<string, string> _workflowStatuses = new();
    private WorkflowCardState? _selectedState => SelectedWorkflowId != null && _states.TryGetValue(SelectedWorkflowId, out var state) ? state : null;
    private string _activeTab = "Execution";

    private CancellationTokenSource? _pollingCts;
    private Task? _pollingTask;
    private Task? _responseTask;
    private DateTimeOffset _lastStateRefresh = DateTimeOffset.MinValue;

    protected override void OnInitialized()
    {
        _definitions = WorkflowRegistry.GetAll().ToList();
        foreach (var def in _definitions)
        {
            var state = new WorkflowCardState(def);
            _states[def.Id] = state;
            _workflowStatuses[def.Id] = state.Status;
        }

        _pollingCts = new CancellationTokenSource();
        _pollingTask = PollRuntimeAsync(_pollingCts.Token);
        _responseTask = RunResponseFeedAsync(_pollingCts.Token);
    }

    protected override void OnParametersSet()
    {
        if (SelectedWorkflowId != null && !_states.ContainsKey(SelectedWorkflowId))
        {
            SelectedWorkflowId = null;
        }
    }

    private void HandleWorkflowSelected(string id)
    {
        Nav.NavigateTo($"/workflows/{id}");
    }

    private async Task RunWorkflowAsync(WorkflowCardState card)
    {
        if (card.IsRunning) return;
        if (!card.Definition.IsEnabled)
        {
            card.Error = "Workflow is disabled.";
            return;
        }

        if (string.IsNullOrWhiteSpace(card.Input))
        {
            card.Error = "Input is required.";
            return;
        }

        card.Error = null;
        card.Response = string.Empty;
        card.Status = "Queued";
        card.IsRunning = true;
        _workflowStatuses[card.Definition.Id] = card.Status;

        var maxAttempts = Math.Max(1, RuntimeOptions.Value.DefaultMaxAttempts);
        card.SessionKey ??= $"workflow-{card.Definition.Id}-{Guid.NewGuid():N}";

        var workItem = new MullaiTaskWorkItem
        {
            TaskId = Guid.NewGuid().ToString("N"),
            SessionKey = card.SessionKey,
            AgentName = $"workflow:{card.Definition.Id}",
            Prompt = card.Input.Trim(),
            Source = MullaiTaskSource.Client,
            MaxAttempts = maxAttempts,
            Metadata = new Dictionary<string, string>
            {
                ["workflowId"] = card.Definition.Id
            }
        };

        card.TaskId = workItem.TaskId;

        try
        {
            await TaskQueue.EnqueueAsync(workItem);
            await StatusStore.MarkQueuedAsync(workItem);
        }
        catch (Exception ex)
        {
            card.IsRunning = false;
            card.Error = $"Failed to queue workflow: {ex.Message}";
            card.Status = "Idle";
            _workflowStatuses[card.Definition.Id] = card.Status;
        }
    }

    private async Task ToggleWorkflowAsync(WorkflowCardState card)
    {
        var enabled = !card.Definition.IsEnabled;
        var updated = new WorkflowDefinition
        {
            Id = card.Definition.Id,
            Name = card.Definition.Name,
            Description = card.Definition.Description,
            Kind = card.Definition.Kind,
            Enabled = enabled,
            Agents = card.Definition.Agents,
            Triggers = card.Definition.Triggers,
            Outputs = card.Definition.Outputs
        };

        await WorkflowTool.UpsertWorkflow(updated);

        card.Definition = updated;
        _definitions = _definitions.Select(d => d.Id == updated.Id ? updated : d).ToList();
        _states[updated.Id] = card;
        if (!enabled)
        {
            card.Status = "Disabled";
            _workflowStatuses[updated.Id] = "Disabled";
        }
        else if (!_workflowStatuses.TryGetValue(updated.Id, out _))
        {
            _workflowStatuses[updated.Id] = card.Status;
        }
    }

    private async Task SendWebhookAsync(WorkflowCardState card, WorkflowTriggersView.WebhookTriggerState trigger)
    {
        if (trigger.IsSending) return;
        if (!card.Definition.IsEnabled)
        {
            trigger.Status = "Workflow is disabled.";
            return;
        }

        trigger.IsSending = true;
        trigger.Status = string.Empty;

        var payload = string.IsNullOrWhiteSpace(trigger.Payload) ? "{}" : trigger.Payload.Trim();
        if (!payload.StartsWith("{", StringComparison.Ordinal))
        {
            payload = $"\"{payload.Replace("\"", "\\\"", StringComparison.Ordinal)}\"";
        }

        try
        {
            var baseUri = Http.BaseAddress ?? new Uri(Nav.BaseUri);
            var request = new HttpRequestMessage(
                HttpMethod.Post,
                new Uri(baseUri, $"api/mullai/workflows/{card.Definition.Id}/triggers/{trigger.TriggerId}"));
            request.Content = new StringContent(payload, Encoding.UTF8, "application/json");
            if (!string.IsNullOrWhiteSpace(trigger.Secret))
            {
                request.Headers.TryAddWithoutValidation("x-mullai-secret", trigger.Secret);
            }

            using var response = await Http.SendAsync(request);
            trigger.Status = response.IsSuccessStatusCode ? "Sent" : $"Failed: {(int)response.StatusCode}";
        }
        catch (Exception ex)
        {
            trigger.Status = $"Error: {ex.Message}";
        }
        finally
        {
            trigger.IsSending = false;
        }
    }

    private async Task PollRuntimeAsync(CancellationToken cancellationToken)
    {
        while (!cancellationToken.IsCancellationRequested)
        {
            try
            {
                await InvokeAsync(async () =>
                {
                    var changed = await SyncRunsAsync(cancellationToken);
                    changed |= await SyncHistoryAsync(cancellationToken);
                    changed |= await SyncStateAsync(cancellationToken);
                    if (changed) StateHasChanged();
                });
            }
            catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
            {
                break;
            }
            catch
            {
                /* Ignore */
            }

            try
            {
                await Task.Delay(500, cancellationToken);
            }
            catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
            {
                break;
            }
        }
    }

    private async Task<bool> SyncStateAsync(CancellationToken cancellationToken)
    {
        if (_activeTab != "State" || _selectedState is null)
        {
            return false;
        }

        if (DateTimeOffset.UtcNow - _lastStateRefresh < TimeSpan.FromSeconds(2))
        {
            return false;
        }

        await RefreshStateAsync(_selectedState, cancellationToken);
        _lastStateRefresh = DateTimeOffset.UtcNow;
        return true;
    }

    private async Task RunResponseFeedAsync(CancellationToken cancellationToken)
    {
        await foreach (var update in ResponseChannel.Reader.ReadAllAsync(cancellationToken))
        {
            var card = _states.Values.FirstOrDefault(x => x.TaskId == update.TaskId);
            if (card != null)
            {
                card.Response = update.Response ?? string.Empty;
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private async Task<bool> SyncRunsAsync(CancellationToken cancellationToken)
    {
        var changed = false;
        foreach (var card in _states.Values)
        {
            if (string.IsNullOrWhiteSpace(card.TaskId)) continue;

            var status = await StatusStore.GetAsync(card.TaskId, cancellationToken);
            if (status == null) continue;

            var oldStatus = card.Status;
            card.Status = status.State.ToString();

            if (status.State is MullaiTaskState.Queued or MullaiTaskState.Running or MullaiTaskState.RetryScheduled)
            {
                if (!string.IsNullOrWhiteSpace(status.Response)) card.Response = status.Response!;
                card.IsRunning = true;
            }
            else
            {
                card.IsRunning = false;
                if (status.State == MullaiTaskState.Succeeded)
                {
                    card.Response = string.IsNullOrWhiteSpace(status.Response) ? "(No response)" : status.Response!;
                    card.Error = null;
                }
                else
                {
                    card.Error = status.Error ?? "Workflow failed.";
                }
            }

            if (oldStatus != card.Status)
            {
                _workflowStatuses[card.Definition.Id] = card.Status;
                changed = true;
            }
        }

        return changed;
    }

    private async Task<bool> SyncHistoryAsync(CancellationToken cancellationToken)
    {
        var recent = await StatusStore.GetRecentAsync(200, cancellationToken);
        var changed = false;

        foreach (var card in _states.Values)
        {
            var runs = recent
                .Where(s => string.Equals(s.WorkflowId, card.Definition.Id, StringComparison.OrdinalIgnoreCase))
                .OrderByDescending(s => s.UpdatedAtUtc)
                .Select(s => new WorkflowRunsView.WorkflowRunRow
                {
                    TaskId = s.TaskId,
                    State = s.State.ToString(),
                    UpdatedAtUtc = s.UpdatedAtUtc,
                    Summary = BuildRunSummary(s),
                    FullText = s.Response ?? s.Error ?? string.Empty
                })
                .ToList();

            var signature = string.Join("|", runs.Select(r => $"{r.TaskId}:{r.State}:{r.UpdatedAtUtc.UtcTicks}"));
            if (card.RecentRunsSignature != signature)
            {
                card.RecentRuns = runs;
                card.RecentRunsSignature = signature;
                changed = true;
            }
        }

        return changed;
    }

    private async Task LoadRunDetailsAsync(WorkflowRunsView.WorkflowRunRow run)
    {
        try
        {
            var baseUri = Http.BaseAddress ?? new Uri(Nav.BaseUri);
            var builder = new UriBuilder(baseUri);
            if (string.Equals(builder.Host, "0.0.0.0", StringComparison.OrdinalIgnoreCase) ||
                string.Equals(builder.Host, "::0", StringComparison.OrdinalIgnoreCase))
            {
                builder.Host = "localhost";
            }

            var requestUri = new Uri(builder.Uri, $"api/mullai/workflows/runs/{run.TaskId}/events?take=500");
            var events = await Http.GetFromJsonAsync<List<WorkflowRunEvent>>(requestUri);
            run.Events = events?
                .Select(evt => new WorkflowRunsView.WorkflowRunEventRow
                {
                    EventType = evt.EventType,
                    CreatedAtUtc = evt.CreatedAtUtc,
                    Payload = FormatJson(evt.PayloadJson)
                })
                .ToList() ?? [];
            run.EventsLoaded = true;
        }
        catch (Exception ex)
        {
            run.EventsError = $"Failed to load events: {ex.Message}";
        }
    }

    private static string FormatJson(string json)
    {
        if (string.IsNullOrWhiteSpace(json))
        {
            return string.Empty;
        }

        try
        {
            using var doc = JsonDocument.Parse(json);
            return JsonSerializer.Serialize(
                doc,
                new JsonSerializerOptions { WriteIndented = true });
        }
        catch
        {
            return json;
        }
    }

    private static string BuildRunSummary(MullaiTaskStatusSnapshot s)
    {
        if (!string.IsNullOrWhiteSpace(s.Error)) return $"Error: {Truncate(s.Error, 80)}";
        if (!string.IsNullOrWhiteSpace(s.Response)) return Truncate(s.Response, 80);
        return "No response yet.";
    }

    private static string Truncate(string text, int max)
    {
        if (string.IsNullOrWhiteSpace(text)) return string.Empty;
        var oneLine = text.ReplaceLineEndings(" ");
        return oneLine.Length <= max ? oneLine : $"{oneLine[..max]}...";
    }

    private async Task RefreshStateAsync(WorkflowCardState card, CancellationToken cancellationToken = default)
    {
        var records = await WorkflowStateStore.GetAllAsync(card.Definition.Id, cancellationToken);
        card.StateEntries = records
            .Select(r => new WorkflowStateView.WorkflowStateEntry
            {
                Key = r.Key,
                JsonValue = r.JsonValue,
                UpdatedAtUtc = r.UpdatedAtUtc
            })
            .OrderBy(r => r.Key)
            .ToList();
    }

    private async Task SaveStateAsync(WorkflowCardState card, WorkflowStateView.WorkflowStateEntry entry)
    {
        try
        {
            await WorkflowStateStore.UpsertAsync(card.Definition.Id, entry.Key, entry.JsonValue);
            entry.Status = "Saved";
            await RefreshStateAsync(card);
        }
        catch (Exception ex)
        {
            entry.Status = $"Error: {ex.Message}";
        }
    }

    private async Task DeleteStateAsync(WorkflowCardState card, WorkflowStateView.WorkflowStateEntry entry)
    {
        await WorkflowStateStore.RemoveAsync(card.Definition.Id, entry.Key);
        await RefreshStateAsync(card);
    }

    public async ValueTask DisposeAsync()
    {
        if (_pollingCts != null)
        {
            _pollingCts.Cancel();
            if (_pollingTask != null)
                try
                {
                    await _pollingTask;
                }
                catch
                {
                }

            if (_responseTask != null)
                try
                {
                    await _responseTask;
                }
                catch
                {
                }

            _pollingCts.Dispose();
        }
    }

    private sealed class WorkflowCardState
    {
        public WorkflowCardState(WorkflowDefinition definition)
        {
            Definition = definition;
            WebhookTriggers = definition.Triggers
                .Where(t => t.Enabled && t.Type.Equals("webhook", StringComparison.OrdinalIgnoreCase))
                .Select(t => new WorkflowTriggersView.WebhookTriggerState
                {
                    TriggerId = string.IsNullOrWhiteSpace(t.Id) ? t.Name : t.Id,
                    DisplayName = string.IsNullOrWhiteSpace(t.Name) ? t.Id : t.Name
                })
                .ToList();
        }

        public WorkflowDefinition Definition { get; set; }
        public string Input { get; set; } = string.Empty;
        public string Status { get; set; } = "Idle";
        public string Response { get; set; } = string.Empty;
        public string? Error { get; set; }
        public bool IsRunning { get; set; }
        public string? TaskId { get; set; }
        public string? SessionKey { get; set; }
        public List<WorkflowRunsView.WorkflowRunRow> RecentRuns { get; set; } = [];
        public string RecentRunsSignature { get; set; } = string.Empty;
        public List<WorkflowTriggersView.WebhookTriggerState> WebhookTriggers { get; }
        public List<WorkflowStateView.WorkflowStateEntry> StateEntries { get; set; } = [];
    }

}
