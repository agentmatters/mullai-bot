<header class="topbar">
    <div class="topbar-left">
        @if (ShowSidebarToggle)
        {
            <button type="button"
                    class="icon-btn topbar-menu"
                    aria-label="Toggle navigation"
                    @onclick="OnToggleSidebar">
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" focusable="false">
                    <path d="M4 7h16M4 12h16M4 17h16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                </svg>
            </button>
        }

        @* <div class="topbar-title"> *@
        @*     <div class="topbar-title-text">@Title</div> *@
        @*     @if (!string.IsNullOrWhiteSpace(Subtitle)) *@
        @*     { *@
        @*         <div class="topbar-title-sub">@Subtitle</div> *@
        @*     } *@
        @* </div> *@
    </div>

    <div class="topbar-right">
        <div class="status-pill">
            <span class="status-indicator" aria-hidden="true"></span>
            @Status
        </div>
        <div class="session-badge">@SessionId</div>
    </div>
</header>

@code {
    [Parameter] public string Title { get; set; } = "Mullai";
    [Parameter] public string? Subtitle { get; set; }

    [Parameter] public string SessionId { get; set; } = "Mullai Assistant";
    [Parameter] public string Status { get; set; } = "Active";

    [Parameter] public bool ShowSidebarToggle { get; set; } = true;
    [Parameter] public EventCallback OnToggleSidebar { get; set; }
}
