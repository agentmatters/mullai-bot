<div class="workflow-tabs">
    @foreach (var tab in _tabs)
    {
        <button class="tab-item @(ActiveTab == tab ? "is-active" : "")"
                @onclick="() => OnTabChanged.InvokeAsync(tab)">
            @tab
        </button>
    }
</div>

@code {
    [Parameter] public string ActiveTab { get; set; } = "Execution";
    [Parameter] public EventCallback<string> OnTabChanged { get; set; }

    private readonly string[] _tabs = ["Execution", "Visual Graph", "History", "Triggers"];
}
